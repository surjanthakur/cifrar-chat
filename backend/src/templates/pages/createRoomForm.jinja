<main class="relative overflow-hidden px-4 py-14 sm:px-6 lg:px-8">
  <section class="flex min-h-[60vh] items-center justify-center">
    <div class="glass-panel w-full max-w-lg rounded-3xl border border-white/20 p-4 shadow-2xl shadow-black/30 sm:p-6 lg:p-8">
      <div class="mb-8 text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-lime-400">
          Private Room
        </p>
        <h1 class="mt-3 text-3xl font-black text-white sm:text-4xl">
          Create Secure Room
        </h1>
        <p class="mt-3 text-sm leading-6 text-zinc-400">
          Add room details and generate a private access key.
        </p>
      </div>

      <form
        id="create-room-form"
        class="w-full space-y-5"
      >
        <div>
          <label for="room_name" class="mb-2 block text-sm font-bold text-zinc-100">
            Room Name
          </label>
          <div class="relative">
            <span
              class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-lime-400"
              aria-hidden="true"
            >
              <i class="fa-solid fa-comments"></i>
            </span>
            <input
              type="text"
              class="peer min-h-14 w-full rounded-xl border border-white/20 bg-white/10 py-3 pl-12 pr-4 text-white outline-none transition duration-300 placeholder:text-zinc-500 hover:border-lime-400/50 focus:border-lime-400 focus:bg-white/[0.12] focus:ring-4 focus:ring-lime-400/15 invalid:[&:not(:placeholder-shown)]:border-rose-400 invalid:[&:not(:placeholder-shown)]:ring-rose-400/15"
              id="room_name"
              name="room_name"
              minlength="3"
              maxlength="20"
              pattern="[A-Za-z0-9_ ]{3,20}"
              placeholder="Project Alpha"
              autocomplete="off"
              required
            />
          </div>
          <p class="mt-2 text-xs leading-5 text-zinc-400 peer-invalid:text-zinc-400">
            Use 3 to 20 characters: letters, numbers, spaces, or underscores.
          </p>
        </div>

        <div>
          <label for="room_owner" class="mb-2 block text-sm font-bold text-zinc-100">
            Room Owner Name
          </label>
          <div class="relative">
            <span
              class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-cyan-300"
              aria-hidden="true"
            >
              <i class="fa-solid fa-user-shield"></i>
            </span>
            <input
              type="text"
              class="min-h-14 w-full rounded-xl border border-white/20 bg-white/10 py-3 pl-12 pr-4 text-white outline-none transition duration-300 placeholder:text-zinc-500 hover:border-cyan-300/50 focus:border-cyan-300 focus:bg-white/[0.12] focus:ring-4 focus:ring-cyan-300/15 invalid:[&:not(:placeholder-shown)]:border-rose-400 invalid:[&:not(:placeholder-shown)]:ring-rose-400/15"
              id="room_owner"
              name="room_owner"
              minlength="2"
              maxlength="15"
              pattern="[A-Za-z0-9_]{2,15}"
              placeholder="surjan_01"
              autocomplete="name"
              required
            />
          </div>
          <p class="mt-2 text-xs leading-5 text-zinc-400">
            Use 2 to 15 characters: letters, numbers, or underscores.
          </p>
        </div>

        <button
          type="submit"
          class="shine-hover inline-flex min-h-14 w-full items-center justify-center gap-3 rounded-xl bg-lime-400 px-6 py-4 text-sm font-black text-zinc-950 shadow-xl shadow-lime-500/20 transition duration-300 hover:scale-[1.02] hover:bg-lime-300 focus:outline-none focus:ring-4 focus:ring-lime-400/25"
        >
          <i class="fa-solid fa-plus"></i>
          Create Private Room
        </button>
      </form>
    </div>
  </section>
</main>
