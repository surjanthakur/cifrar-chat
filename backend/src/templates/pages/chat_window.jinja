<link
  rel="stylesheet"
  href="{{ url_for('static', path='/css/chat_window.css') }}"
/>
<main class="chat-window-page" id="chat-window-root">
  <section
    class="chat-window-page__shell"
    id="chat-window"
    aria-label="Room chat"
  >
    <div class="chat-container">
      <!-- Header -->
      <header class="chat-header" role="banner">
        <div class="chat-header__info channel-info">
          <span class="chat-header__title channel-name">steve jones</span>
          <span class="chat-header__meta online-count">23 online</span>
        </div>
        <div class="chat-header__actions header-actions">
          <button type="button" class="icon-btn" aria-label="Members">
            <i class="fa-solid fa-users" aria-hidden="true"></i>
          </button>
          <button type="button" class="icon-btn" aria-label="History">
            <i class="fa-regular fa-clock" aria-hidden="true"></i>
          </button>
          <button type="button" class="icon-btn" aria-label="Close">
            <i class="fa-regular fa-circle-xmark" aria-hidden="true"></i>
          </button>
        </div>
      </header>

      <!-- Messages -->
      <div class="messages-container" role="log" aria-live="polite" aria-relevant="additions">
        <article class="message-group">
          <div class="message-content">
            <div class="message-header">
              <span class="author">test</span>
              <span class="timestamp">12:03</span>
            </div>
            <div class="message-body">hy this is demo messages</div>
          </div>
        </article>
      </div>

      <!-- Composer -->
      <footer class="chat-input-area" role="contentinfo">
        <div class="input-wrapper">
          <button type="button" class="attach-btn" aria-label="Attach">
            <i class="fa-solid fa-plus" aria-hidden="true"></i>
          </button>
          <input
            type="text"
            class="message-input"
            placeholder="say anything..."
            autocomplete="off"
          />
          <button type="button" class="send-btn" aria-label="Send message">➤</button>
        </div>
      </footer>
    </div>
  </section>
</main>
