<main class="relative overflow-hidden" data-home-motion>
  <section class="home-hero hero-shell relative overflow-hidden" data-motion-hero>
    <div class="hero-aurora-layer" data-parallax-layer aria-hidden="true"></div>
    <div
      class="relative z-10 mx-auto flex w-full max-w-6xl flex-col items-center justify-center px-4 pb-16 pt-20 text-center sm:px-6 sm:pb-20 sm:pt-24 lg:px-8"
    >
      <p
        class="glass-panel shine-hover inline-flex items-center gap-2 rounded-full px-4 py-2 text-xs font-semibold shadow-lg shadow-emerald-950/20"
        data-motion-item
      >
        <span class="size-2 rounded-full bg-red-600 shadow-[0_0_18px_rgba(110,231,183,0.95)]"></span>
        <span data-typewriter="No one sees what you do here">No one sees what you do here</span>
      </p>
      <h1
        class="mt-8 max-w-5xl text-5xl font-black leading-tight text-zinc-50 sm:text-5xl md:text-6xl lg:text-7xl"
        data-motion-item
      >
        Privacy With
        <span class="text-gradient">Secured Chats</span>
      </h1>
      <p
        class="mt-6 max-w-2xl text-base leading-8 text-zinc-300 sm:text-lg"
        data-motion-item
      >
        Immediate peer-to-peer encryption. No email, no phone number, no
        centralized database. Just a direct, ephemeral link between
        participants.
      </p>

      <div
        id="join-room"
        class="mt-10 flex w-full max-w-xl flex-col gap-4 sm:flex-row sm:justify-center"
        data-motion-item
      >
        <a
          href="/api/rooms/create/"
          class="shine-hover magnetic-button pulse-cta inline-flex min-h-14 flex-1 items-center justify-center gap-3 rounded-xl bg-emerald-300 px-6 py-4 text-sm font-bold text-zinc-950 shadow-xl shadow-emerald-500/20 transition duration-300 hover:scale-[1.03] hover:bg-emerald-200"
          data-magnetic
        >
          <i class="fa-solid fa-plus"></i>
          Create A Private Room
        </a>
        <a
          href="/api/rooms/join/"
          class="shine-hover magnetic-button inline-flex min-h-14 flex-1 items-center justify-center gap-3 rounded-xl border border-white/10 bg-white/[0.08] px-6 py-4 text-sm font-bold text-zinc-100 shadow-xl shadow-black/20 transition duration-300 hover:scale-[1.03] hover:border-cyan-300/40 hover:bg-cyan-300/10"
          data-magnetic
        >
          <i class="fa-solid fa-right-to-bracket"></i>
          Join A Private Room
        </a>
      </div>
    </div>
  </section>
  {% include "components/features_cards.html" %}
</main>
<script type="module">
  import { animate, inView, scroll } from "https://cdn.jsdelivr.net/npm/motion@latest/+esm";

  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const animateElements = (elements, keyframes, options = {}) => {
    if (!elements.length) {
      return;
    }

    if (prefersReducedMotion) {
      elements.forEach((element) => {
        Object.assign(element.style, {
          opacity: "1",
          transform: "none",
        });
      });
      return;
    }

    elements.forEach((element, index) => {
      animate(element, keyframes, {
        duration: 0.7,
        delay: index * 0.12,
        easing: [0.22, 1, 0.36, 1],
        ...options,
      });
    });
  };

  const heroItems = Array.from(document.querySelectorAll("[data-motion-item]"));
  animateElements(heroItems, { opacity: [0, 1], y: [32, 0], filter: ["blur(8px)", "blur(0px)"] });

  const typewriter = document.querySelector("[data-typewriter]");
  if (typewriter && !prefersReducedMotion) {
    const phrase = typewriter.dataset.typewriter || typewriter.textContent.trim();
    typewriter.textContent = "";

    [...phrase].forEach((character, index) => {
      window.setTimeout(() => {
        typewriter.textContent += character;
      }, 32 * index);
    });
  }

  const navbar = document.querySelector("[data-motion-navbar]");
  if (navbar && !prefersReducedMotion) {
    animate(navbar, { opacity: [0, 1], y: [-18, 0], scale: [0.98, 1] }, {
      duration: 0.65,
      easing: [0.22, 1, 0.36, 1],
    });
  }

  const parallaxLayer = document.querySelector("[data-parallax-layer]");
  const hero = document.querySelector("[data-motion-hero]");
  if (parallaxLayer && hero && !prefersReducedMotion) {
    scroll(
      animate(parallaxLayer, { y: [-42, 42], scale: [1.05, 1.12] }, { easing: "linear" }),
      { target: hero },
    );
  }

  const featureCards = Array.from(document.querySelectorAll("[data-feature-card]"));

  inView("[data-feature-card]", (card) => {
    animate(card, { opacity: [0, 1], y: [36, 0], scale: [0.96, 1] }, {
      duration: prefersReducedMotion ? 0.01 : 0.65,
      delay: prefersReducedMotion ? 0 : featureCards.indexOf(card) * 0.08,
      easing: [0.22, 1, 0.36, 1],
    });
  }, { margin: "0px 0px -12% 0px" });

  document.querySelectorAll("[data-floating-element]").forEach((element, index) => {
    if (prefersReducedMotion) {
      return;
    }

    animate(element, { y: [0, -7, 0] }, {
      duration: 2.8 + index * 0.15,
      repeat: Infinity,
      easing: "ease-in-out",
    });
  });

  document.querySelectorAll("[data-feature-card]").forEach((card) => {
    if (prefersReducedMotion) {
      return;
    }

    card.addEventListener("pointermove", (event) => {
      const bounds = card.getBoundingClientRect();
      const x = event.clientX - bounds.left;
      const y = event.clientY - bounds.top;
      const rotateY = ((x / bounds.width) - 0.5) * 9;
      const rotateX = -((y / bounds.height) - 0.5) * 9;

      card.style.setProperty("--card-x", `${x}px`);
      card.style.setProperty("--card-y", `${y}px`);

      animate(card, {
        rotateX,
        rotateY,
        scale: 1.025,
        boxShadow: "0 26px 70px rgba(34, 197, 94, 0.18)",
      }, {
        duration: 0.18,
        easing: "ease-out",
      });
    });

    card.addEventListener("pointerleave", () => {
      animate(card, {
        rotateX: 0,
        rotateY: 0,
        scale: 1,
        boxShadow: "0 20px 45px rgba(0, 0, 0, 0.2)",
      }, {
        duration: 0.45,
        easing: [0.22, 1, 0.36, 1],
      });
    });
  });

  document.querySelectorAll("[data-magnetic]").forEach((button) => {
    if (prefersReducedMotion) {
      return;
    }

    button.addEventListener("pointermove", (event) => {
      const bounds = button.getBoundingClientRect();
      const x = event.clientX - bounds.left - bounds.width / 2;
      const y = event.clientY - bounds.top - bounds.height / 2;

      animate(button, { x: x * 0.12, y: y * 0.18 }, { duration: 0.22, easing: "ease-out" });
    });

    button.addEventListener("pointerleave", () => {
      animate(button, { x: 0, y: 0 }, { duration: 0.45, easing: [0.22, 1, 0.36, 1] });
    });
  });
</script>
 